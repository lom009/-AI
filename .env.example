ASR_PROVIDER=tencent
ASR_MODE=streaming
HOST=0.0.0.0
PORT=8788

TENCENT_APP_ID=your_app_id
TENCENT_SECRET_ID=your_secret_id
TENCENT_SECRET_KEY=your_secret_key
TENCENT_ASR_ENGINE_MODEL_TYPE=16k_zh
TENCENT_ASR_VOICE_FORMAT=1
TENCENT_ASR_NEED_VAD=1
TENCENT_ASR_SAMPLE_RATE=16000

ALLOW_REAL_PATIENT_AUDIO=false
LOG_AUDIO_PAYLOAD=false
